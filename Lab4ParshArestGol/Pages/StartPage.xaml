<Page x:Class="Lab4ParshArestGol.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lab4ParshArestGol"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="800"
      Title="StartPage">
    <Page.Resources>
        <Style x:Name="LinkStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Candara"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="MiniCardButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="30"
                                BorderThickness="0"
                                Margin="10"
                                Width="210" Height="280"
                                RenderTransformOrigin="0.5 0.5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Direction="275" Opacity="0.5"/>
                            </Border.Effect>

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <Grid>
                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F9F9F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.99" ScaleY="0.99"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#977C5F"/>
            <Setter Property="Margin" Value="20 30 20 0"/>
            <Setter Property="FontFamily" Value="Arial Black"/>
        </Style>
        <Style x:Key="BottomLinksStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#977C5F"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Page.Resources>
    <Grid Background="#EAEADA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition Height="350"></RowDefinition>
            <RowDefinition Height="370"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="3" Height="60"
                Background="#B1AF88"/>

        <Border Grid.Column="0" Grid.Row="0"
                BorderThickness="0 0 1 0" BorderBrush="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="FAQ" Click="Button_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Grid.Row="0"
                BorderThickness="1 0 1 0" BorderBrush="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="Узнать о нас" Click="Button_Click_1" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Grid.Row="0"
                BorderThickness="1 0 0 0" BorderBrush="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="Форум" Click="Button_Click_2" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>


        <Border Grid.Row="1" Grid.Column="0">
            <Button x:Name="UserLogginingBtn" Height="50" Width="50"
                    HorizontalAlignment="Left" Margin="40 0 0 0"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand"
                    Click="UserLogginingBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Image x:Name="BtnImg"
                                   Source="/Images/userIcon.png"
                                   Width="50" Height="50"
                                   Opacity="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnImg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.5"/>
                </Button.Effect>
            </Button>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="3">
            <StackPanel Margin="0 25" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBox Height="40" Width="300" VerticalContentAlignment="Center"
                         Padding="20 5" FontFamily="Candara" FontSize="20">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </TextBox.Resources>
                    <TextBox.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                    </TextBox.Effect>
                </TextBox>

                <Button Width="50" Height="50" Margin="5"
                        HorizontalContentAlignment="Center" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <Image x:Name="srchImg"
                                       Source="/Images/searchIcon.png"
                                       Width="50" Height="50"
                                       Opacity="1"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="srchImg" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.5"/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="2">
            <Button x:Name="SettingsButton"
                    Height="50" Width="50"
                    HorizontalAlignment="Right" Margin="0 0 40 0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Image x:Name="ButtonIm"
                                   Source="/Images/settingIcon.png"
                                   Width="50" Height="50"
                                   Opacity="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonIm" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                </Button.Effect>
            </Button>
        </Border>


        <Border Grid.Row="2" Grid.ColumnSpan="3">
            <StackPanel Margin="30 20">
                <Button Width="650" Height="310"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="forumCard"
                                    Background="White"
                                    CornerRadius="30"
                                    Padding="30 20 0 0"
                                    BorderThickness="0"
                                    RenderTransformOrigin="0.5 0.5">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Direction="275" Opacity="0.5"/>
                                </Border.Effect>

                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"></ColumnDefinition>
                                        <ColumnDefinition Width="*"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="10 0 0 20">
                                        <TextBlock Text="КАК МЫ МОЖЕМ ПОМОЧЬ??" FontSize="32" 
                                                   Foreground="#977C5F" FontFamily="Arial Black"
                                                   FontWeight="Bold" TextWrapping="Wrap"
                                                   Margin="0 15 0 0"/>
                                        <TextBlock Text="ЗАЙДИТЕ НА ФОРУМ И УЗНАЙТЕ БОЛЬШЕ О НАС!" FontSize="20"
                                                   Foreground="#3F372C" FontFamily="Arial" FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   Margin="0 15 0 15"/>
                                        <TextBlock Text="УСПЕЙТЕ ПОМОЧЬ НАШИМ МАЛЕНЬКИМ ДРУЗЬЯМ УЖЕ СЕЙЧАС!" FontSize="20"
                                                   Foreground="#3F372C" FontFamily="Arial" FontWeight="Bold"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Image Grid.ColumnSpan="2"
                                           Source="/Images/pets1Card.png"
                                           Stretch="Uniform"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                           Width="400"/>
                                </Grid>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="forumCard" Property="Background" Value="#F9F9F9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="forumCard" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.99" ScaleY="0.99"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>


        <Button x:Name="SupportButton"
                Grid.Column="0" Grid.Row="3"
                Style="{StaticResource MiniCardButton}">
            <StackPanel>
                <TextBlock Text="ПОДДЕРЖАТЬ ПИТОМНИК" Style="{StaticResource CardTextStyle}"/>
                <Image Source="/Images/pets2Card.png"/>
            </StackPanel>
        </Button>

        <Button x:Name="QuestionButton"
        Grid.Column="1" Grid.Row="3"
        Style="{StaticResource MiniCardButton}">
            <StackPanel>
                <TextBlock Text="УЗНАТЬ МЕСТО И ВРЕМЯ РАБОТЫ" Style="{StaticResource CardTextStyle}"/>
                <Image Source="/Images/pets4Card.png"/>
            </StackPanel>
        </Button>

        <Button x:Name="LookingButton"
                Grid.Column="2" Grid.Row="3"
                Style="{StaticResource MiniCardButton}">
            <StackPanel>
                <TextBlock Text="ПОСМОТРЕТЬ НА ЖИЛЬЦОВ" Style="{StaticResource CardTextStyle}"/>
                <Image Source="/Images/pets3Card.png" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Button>


        <Border Grid.Row="4" Grid.ColumnSpan="3" Background="#D8BF97"/>

        <Border Grid.Row="4" Grid.Column="0"
                BorderThickness="0 0 1 0" BorderBrush="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="Partnership" Cursor="Hand">
                    <TextBlock Text="ПАРТНЕРСКИЕ ПРОГРАММЫ"
                               Style="{StaticResource BottomLinksStyle}"/>
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Grid.Column="1"
                BorderThickness="1 0 1 0" BorderBrush="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="Question" Cursor="Hand">
                    <TextBlock Text="ЗАДАТЬ         ВОПРОС"
                               Style="{StaticResource BottomLinksStyle}"/>
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Grid.Column="2"
                BorderThickness="1 0 0 0" BorderBrush="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="Contact" Cursor="Hand">
                    <TextBlock Text="КОНТАКТНАЯ ИНФОРМАЦИЯ"
                               Style="{StaticResource BottomLinksStyle}"/>
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
