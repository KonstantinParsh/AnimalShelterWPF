<Window x:Class="Lab4ParshArestGol.Pages.RegWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab4ParshArestGol.Pages"
        mc:Ignorable="d"
        Title="Gromify (регистрация)" Height="850" Width="1000" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="OtherButtons" TargetType="Button">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Background" Value="#896033"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="12" 
                        SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5 0.5">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="3" Color="Black" Opacity="0.3" Direction="270"/>
                            </Border.Effect>

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A67B4D"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6D4A28"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.99" ScaleY="0.99"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#D8BF97"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="400"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15 5"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Border x:Name="templateRoot" 
                Background="White" 
                CornerRadius="20" 
                SnapsToDevicePixels="true">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1"
                                          Opacity="0.5"/>
                    </Border.Effect>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Path x:Name="arrow" 
                  Grid.Column="1" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Data="M 0 0 L 7 8 L 14 0 Z" 
                  Fill="#D8BF97" 
                  Stretch="None"/>
                </Grid>
            </Grid>
        </ControlTemplate>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#D8BF97"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Width" Value="400"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Padding" Value="20 0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="true">
                            <ToggleButton x:Name="toggleButton" 
                                  Template="{StaticResource ComboBoxToggleButton}" 
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press"/>

                            <ContentPresenter x:Name="contentPresenter" 
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Margin="{TemplateBinding Padding}"
                                      IsHitTestVisible="false"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Grid.ColumnSpan="2" 
                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                           Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" 
                                Background="White" 
                                CornerRadius="10"
                                BorderBrush="#D8BF97" 
                                BorderThickness="1"
                                Margin="0 5 0 0"
                                MinWidth="{Binding ActualWidth, ElementName=templateRoot}" 
                                MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegButton" TargetType="Button">
            <Setter Property="Background" Value="#B1AF88"/>
            <Setter Property="Width" Value="400"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="15 15 15 35"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}">
                            <TextBlock Text="ЗАРЕГИСТРИРОВАТЬСЯ" FontSize="24" FontFamily="Arial" FontWeight="Bold"
                               TextAlignment="Center" VerticalAlignment="Center"
                               HorizontalAlignment="Center" Foreground="White"
                                       RenderTransformOrigin="0.5 0.5"/>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B1AF68"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.99" ScaleY="0.99"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#EAEADA">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
               Text="РЕГИСТРАЦИЯ" FontSize="32"
               FontFamily="Arial Black" Foreground="#896033"
               VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
            </TextBlock.Effect>
        </TextBlock>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBox Style="{StaticResource TextBoxStyle}" Text="ФАМИЛИЯ*" x:Name="FirstNameField" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="ФАМИЛИЯ*">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <TextBox Style="{StaticResource TextBoxStyle}" Text="ИМЯ*" x:Name="SecondNameField" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="ИМЯ*">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <TextBox Style="{StaticResource TextBoxStyle}" Text="ОТЧЕСТВО" x:Name="ThirdNameField" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="ОТЧЕСТВО">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <TextBox Style="{StaticResource TextBoxStyle}" Text="НОМЕР ТЕЛЕФОНА*" x:Name="PhoneNumberField" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="НОМЕР ТЕЛЕФОНА*">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <ComboBox Style="{StaticResource ComboBoxStyle}" x:Name="RoleField">
                        <ComboBoxItem Content="ВЫБЕРИТЕ РОЛЬ*" IsEnabled="False" IsSelected="True" Visibility="Collapsed"/>
                        <ComboBoxItem Content="Администратор"/>
                        <ComboBoxItem Content="Пользователь"/>
                        <ComboBoxItem Content="Волонтер"/>
                        <ComboBoxItem Content="Ветеринарный врач"/>
                    </ComboBox>

                    <TextBox Style="{StaticResource TextBoxStyle}" Text="НИК*" x:Name="LoginField" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="НИК*">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <TextBox Style="{StaticResource TextBoxStyle}" Text="ПАРОЛЬ*" x:Name="PasswordField" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="ПАРОЛЬ*">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <TextBox Style="{StaticResource TextBoxStyle}" Text="ПОВТОРИТЕ ПАРОЛЬ*" x:Name="PasswordRepeatField" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="ПОВТОРИТЕ ПАРОЛЬ*">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                </StackPanel>
            </Grid>

            <Button Style="{StaticResource RegButton}" Content="ЗАРЕГИСТРИРОВАТЬСЯ" HorizontalAlignment="Center"
                    x:Name="RegBut" Click="RegBut_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
                <Button.Effect>
                    <DropShadowEffect BlurRadius="3" Direction="300" ShadowDepth="1" Opacity="0.5"/>
                </Button.Effect>
            </Button>
        </StackPanel>

        <Border Grid.Row="2" Background="#D8BF97"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Style="{StaticResource OtherButtons}" 
                    Content="НА ГЛАВНУЮ"
                    x:Name="BackToMain" Click="BackToMain_Click"/>
            <Button Style="{StaticResource OtherButtons}" 
                    Content="ВОЙТИ"
                    x:Name="LogInBut" Click="LogInBut_Click"/>
        </StackPanel>
    </Grid>
</Window>
